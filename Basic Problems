https://www.geeksforgeeks.org/problems/count-digits5716/1
class Solution:
    def evenlyDivides(self, n):
        # code here
        temp=n
        count=0
        while (temp>0):
            digit=temp%10
            if(digit!=0 and n%digit==0):
                count=count+1
            temp//=10
        return count
